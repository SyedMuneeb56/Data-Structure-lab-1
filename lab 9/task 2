#include <iostream>
#include <string>
using namespace std;


class SongNode {
public:
    int songID;
    string songName;
    float duration;

    SongNode* next;
    SongNode* prev;

   
    SongNode(int id, string name, float dur) {
        songID = id;
        songName = name;
        duration = dur;

        next = nullptr;
        prev = nullptr;
    }
};


class PlaylistManager {
private:
    SongNode* head;
    SongNode* tail;
    SongNode* currentSong;

public:
  
    PlaylistManager() {
        head = nullptr;
        tail = nullptr;
        currentSong = nullptr;
    }

    void addSong(int id, string name, float dur) {
        SongNode* newSong = new SongNode(id, name, dur);

        if (head == nullptr) {
            head = tail = newSong;
            currentSong = head;
        }
        else {
            tail->next = newSong;
            newSong->prev = tail;
            tail = newSong;
        }

        cout << "Song added successfully: " << name << endl;
    }

    void deleteSong(string name) {
        
        if (head == nullptr) {
            cout << "Playlist is empty!" << endl;
            return;
        }

        SongNode* temp = head;

        while (temp != nullptr && temp->songName != name) {
            temp = temp->next;
        }

        
        if (temp == nullptr) {
            cout << "Song not found!" << endl;
            return;
        }

       
        if (temp == head) {
            head = head->next;

            if (head != nullptr)
                head->prev = nullptr;
        }

        if (temp == tail) {
            tail = tail->prev;

            if (tail != nullptr)
                tail->next = nullptr;
        }

        
        if (temp->prev != nullptr)
            temp->prev->next = temp->next;

        if (temp->next != nullptr)
            temp->next->prev = temp->prev;

        
        if (currentSong == temp) {
            currentSong = head;
        }

        cout << "Deleted song: " << temp->songName << endl;

        delete temp;
    }

    
    void playCurrentSong() {
        if (currentSong == nullptr) {
            cout << "No song available!" << endl;
            return;
        }

        cout << "\nNow Playing: "
            << currentSong->songName
            << " (" << currentSong->duration << " mins)"
            << endl;
    }

    
    void playNext() {
        if (currentSong == nullptr) {
            cout << "Playlist is empty!" << endl;
            return;
        }

        if (currentSong->next != nullptr) {
            currentSong = currentSong->next;
            playCurrentSong();
        }
        else {
            cout << "You are at the last song!" << endl;
        }
    }

    
    void playPrevious() {
        if (currentSong == nullptr) {
            cout << "Playlist is empty!" << endl;
            return;
        }

        if (currentSong->prev != nullptr) {
            currentSong = currentSong->prev;
            playCurrentSong();
        }
        else {
            cout << "You are at the first song!" << endl;
        }
    }

    
    void reversePlaylist() {
        if (head == nullptr) {
            cout << "Playlist is empty!" << endl;
            return;
        }

        SongNode* current = head;
        SongNode* temp = nullptr;

        
        while (current != nullptr) {
            temp = current->prev;
            current->prev = current->next;
            current->next = temp;

            current = current->prev;
        }

       
        temp = head;
        head = tail;
        tail = temp;

        
        currentSong = head;

        cout << "Playlist reversed successfully!" << endl;
    }

    
    void displayPlaylist() {
        if (head == nullptr) {
            cout << "Playlist is empty!" << endl;
            return;
        }

        SongNode* temp = head;

        cout << " PLAYLIST " << endl;

        while (temp != nullptr) {
            cout << "Song ID: " << temp->songID << endl;
            cout << "Song Name: " << temp->songName << endl;
            cout << "Duration: " << temp->duration << " mins" << endl;

            temp = temp->next;
        }
    }
};


int main() {

    PlaylistManager playlist;

    
    playlist.addSong(101, "Shape of You", 4.2);
    playlist.addSong(102, "Believer", 3.8);
    playlist.addSong(103, "Blinding Lights", 3.5);
    playlist.addSong(104, "Perfect", 4.5);

    
    playlist.displayPlaylist();

   
    playlist.playCurrentSong();

    cout << "Playing next songs" << endl;
    playlist.playNext();
    playlist.playNext();

    cout << "Playing previous song" << endl;
    playlist.playPrevious();

    
    cout << "Deleting a song" << endl;
    playlist.deleteSong("Believer");

   
    playlist.displayPlaylist();

   
    playlist.reversePlaylist();

    
    playlist.displayPlaylist();

    return 0;
}
